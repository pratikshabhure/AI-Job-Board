# ==========================================
# AI Job Board - Environment Configuration
# ==========================================

# ==========================================
# DATABASE Configuration
# ==========================================
# SQLite database URL (default: sqlite:///./job_board.db)
# For production, use PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./job_board.db

# ==========================================
# LLM (Groq AI) Configuration
# ==========================================
# Groq API Key - Get from https://console.groq.com
# Required for AI-powered candidate matching
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq Model - LLM model to use for preference extraction
# Valid options: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma-7b-it
GROQ_MODEL=llama-3.1-8b-instant

# ==========================================
# JWT & Security Configuration
# ==========================================
# Secret key for JWT token generation (change in production!)
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production

# JWT Token expiration time in minutes (default: 43200 = 30 days)
JWT_EXPIRE_MINUTES=43200

# ==========================================
# CORS Configuration
# ==========================================
# Allowed origins for CORS (comma-separated)
# Default includes localhost for development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==========================================
# Server Configuration
# ==========================================
# Server host and port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ==========================================
# Frontend Configuration
# ==========================================
# Frontend URL (used for redirects and CORS)
FRONTEND_URL=http://localhost:5173

# ==========================================
# Email Configuration (Optional)
# ==========================================
# SMTP settings for OTP and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com

# ==========================================
# Development Configuration
# ==========================================
# Set to 'development' or 'production'
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=true